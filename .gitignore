# OS
.DS_Store
Thumbs.db

# User-managed inputs. The repo ships a template for quotes; combinations
# is a working file. locations.csv is committed as a starter geocode cache
# and grows locally as Nominatim adds new cities (see instructions.txt for
# how to silence the resulting git noise).
data/quotes.csv
data/combinations.csv

# Per-carrier scratch notes (personal TODO files, not part of the repo)
src/carriers/*/pendingFixes*

# Generated runtime data
src/data/*/raw/
src/data/*/log/
src/data/*/csvs/
src/data/*/canonical/
src/data/*/html/
src/data/tables/

# Carriers should still ship their lookup assets
!src/carriers/*/assets/
